---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="联系我们 - 满分虎体育">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-primary), #FF8C42);">
    <div class="container"><h1>联系我们</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="gap:48px;">
        <!-- 预约表单 -->
        <div class="contact-form">
          <h2 style="margin-bottom:24px;">在线预约</h2>
          <div class="survey-card">
            <div class="survey-icon">📋</div>
            <h3>预约报名</h3>
            <p>请填写预约信息，我们会尽快与您联系！</p>
            <a href="https://wj.qq.com/s2/26539023/0ba7" target="_blank" rel="noopener" class="btn btn-primary" style="display:inline-block;text-align:center;padding:14px 32px;font-size:1.1rem;">
              🏃 立即预约报名 →
            </a>
            <p class="survey-note">点击后在腾讯问卷中填写，信息直接进入后台</p>
          </div>
        </div>

        <!-- 联系信息 -->
        <div class="contact-info">
          <h2 style="margin-bottom:24px;">联系方式</h2>
          <div class="info-item">
            <span class="icon">📞</span>
            <div>
              <strong>联系电话</strong>
              <p class="text-muted">待填写</p>
            </div>
          </div>
          <div class="info-item">
            <span class="icon">⏰</span>
            <div>
              <strong>营业时间</strong>
              <p class="text-muted">待填写</p>
            </div>
          </div>

          <!-- 微信二维码 -->
          <div class="info-item" style="margin-top:32px;">
            <div class="qrcode-placeholder">
              <div class="placeholder" style="min-height:160px;">
                💚 微信二维码<br/>
                <small style="font-size:0.8rem;">放入文件：public/images/wechat-qr.png</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }

  .survey-card {
    background: linear-gradient(135deg, #fff8f0, #fff);
    border: 2px solid var(--c-primary);
    border-radius: var(--radius-lg);
    padding: 40px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(255,107,53,0.1);
  }
  .survey-icon { font-size: 3rem; margin-bottom: 16px; }
  .survey-card h3 { font-size: 1.5rem; margin-bottom: 12px; color: var(--c-text); }
  .survey-card p { color: var(--c-text-muted); margin-bottom: 24px; font-size: 0.95rem; }
  .survey-note { font-size: 0.8rem; color: var(--c-text-muted); margin-top: 16px; }

  .info-item { display: flex; gap: 16px; margin-bottom: 24px; }
  .info-item .icon { font-size: 1.5rem; }
  .info-item strong { display: block; margin-bottom: 4px; }
  .text-muted { color: var(--c-text-muted); }

  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr !important; }
  }
</style>