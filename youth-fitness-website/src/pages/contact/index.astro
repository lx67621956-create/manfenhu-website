---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="联系我们 - 满分虎体育">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-primary), #FF8C42);">
    <div class="container"><h1>联系我们</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="gap:48px;">
        <!-- 预约表单 -->
        <div class="contact-form">
          <h2 style="margin-bottom:24px;">在线预约</h2>
          <form>
            <div class="form-group">
              <label>家长姓名</label>
              <input type="text" placeholder="请填写" />
            </div>
            <div class="form-group">
              <label>联系电话</label>
              <input type="tel" placeholder="请填写" />
            </div>
            <div class="form-group">
              <label>孩子姓名</label>
              <input type="text" placeholder="请填写" />
            </div>
            <div class="form-group">
              <label>孩子年龄</label>
              <select>
                <option value="">请选择</option>
                <option>4-6岁</option>
                <option>7-9岁</option>
                <option>10-12岁</option>
                <option>13-15岁</option>
                <option>16岁及以上</option>
              </select>
            </div>
            <div class="form-group">
              <label>意向课程</label>
              <select>
                <option value="">请选择</option>
                <option>中考体育特训</option>
                <option>少儿体能训练</option>
                <option>手球专项特训</option>
              </select>
            </div>
            <div class="form-group">
              <label>备注信息</label>
              <textarea rows="4" placeholder="请填写"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;">提交预约</button>
          </form>
        </div>

        <!-- 联系信息 -->
        <div class="contact-info">
          <h2 style="margin-bottom:24px;">联系方式</h2>
          <div class="info-item">
            <span class="icon">📞</span>
            <div>
              <strong>联系电话</strong>
              <p class="text-muted">待填写</p>
            </div>
          </div>
          <div class="info-item">
            <span class="icon">⏰</span>
            <div>
              <strong>营业时间</strong>
              <p class="text-muted">待填写</p>
            </div>
          </div>

          <!-- 微信二维码 -->
          <div class="info-item" style="margin-top:32px;">
            <div class="qrcode-placeholder">
              <div class="placeholder" style="min-height:160px;">
                💚 微信二维码<br/>
                <small style="font-size:0.8rem;">放入 logo 文件：public/images/logo.png</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; margin-bottom: 8px; font-weight: 500; }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%; padding: 12px 16px;
    border: 2px solid var(--c-border); border-radius: var(--radius);
    font-size: 1rem; transition: border-color .2s;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none; border-color: var(--c-primary);
  }
  
  .info-item { display: flex; gap: 16px; margin-bottom: 24px; }
  .info-item .icon { font-size: 1.5rem; }
  .info-item strong { display: block; margin-bottom: 4px; }
  .text-muted { color: var(--c-text-muted); }
  
  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr !important; }
  }
</style>
