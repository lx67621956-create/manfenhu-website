---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="训练环境 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, #57606F, #8397A7);">
    <div class="container"><h1>训练环境</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">场地照片</h2>
      <div class="grid-3">
        <div class="placeholder" style="min-height:200px;">📷 场地照片1</div>
        <div class="placeholder" style="min-height:200px;">📷 场地照片2</div>
        <div class="placeholder" style="min-height:200px;">📷 场地照片3</div>
        <div class="placeholder" style="min-height:200px;">📷 场地照片4</div>
        <div class="placeholder" style="min-height:200px;">📷 场地照片5</div>
        <div class="placeholder" style="min-height:200px;">📷 场地照片6</div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--c-surface);">
    <div class="container">
      <h2 class="section-title">训练视频</h2>
      <div class="placeholder" style="min-height:360px;">🎬 训练视频位置（建议上传至视频平台后嵌入链接）</div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
</style>
