---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="师资团队 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-primary), #FF8C42);">
    <div class="container"><h1>师资团队</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">教练团队</h2>
      <div class="grid-4">
        <div class="card coach-card">
          <div class="placeholder" style="min-height:200px;">👤 教练照片1</div>
          <div class="card-body">
            <h3>教练姓名</h3>
            <p class="text-muted">职称/资质待填写</p>
            <p class="text-muted">简介待填写...</p>
          </div>
        </div>
        <div class="card coach-card">
          <div class="placeholder" style="min-height:200px;">👤 教练照片2</div>
          <div class="card-body">
            <h3>教练姓名</h3>
            <p class="text-muted">职称/资质待填写</p>
            <p class="text-muted">简介待填写...</p>
          </div>
        </div>
        <div class="card coach-card">
          <div class="placeholder" style="min-height:200px;">👤 教练照片3</div>
          <div class="card-body">
            <h3>教练姓名</h3>
            <p class="text-muted">职称/资质待填写</p>
            <p class="text-muted">简介待填写...</p>
          </div>
        </div>
        <div class="card coach-card">
          <div class="placeholder" style="min-height:200px;">👤 教练照片4</div>
          <div class="card-body">
            <h3>教练姓名</h3>
            <p class="text-muted">职称/资质待填写</p>
            <p class="text-muted">简介待填写...</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--c-surface);">
    <div class="container">
      <h2 class="section-title">资质荣誉</h2>
      <div class="grid-4">
        <div class="placeholder" style="min-height:120px;">🏆 资质证书1</div>
        <div class="placeholder" style="min-height:120px;">🏆 资质证书2</div>
        <div class="placeholder" style="min-height:120px;">🏆 资质证书3</div>
        <div class="placeholder" style="min-height:120px;">🏆 资质证书4</div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  .coach-card .card-body { padding: 16px; text-align: center; }
  .coach-card h3 { margin-bottom: 4px; }
  .text-muted { color: var(--c-text-muted); font-size: .9rem; }
</style>
