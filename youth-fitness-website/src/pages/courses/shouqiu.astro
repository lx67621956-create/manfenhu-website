---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="手球专项特训 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-accent), #00E676);">
    <div class="container"><h1>手球专项特训</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items:start;">
        <img src="/images/courses/shouqiu.jpg.png" alt="手球专项特训" class="course-hero-img" />
        <div class="course-content">
          <h2 style="margin-bottom:16px;">专业启航，成就未来</h2>
          <p class="course-intro">
            渴望让孩子接受专业的体育训练，并拥有更广阔的发展空间？我们的手球专项特训是您的不二之选。由国家队教练亲自执教，提供最高水平的专业技战术培训。课程不仅注重个人技术提升，更强调团队协作精神的培养。每节课 90 分钟，学员将有机会参与北京市乃至全国性的专业比赛，更有机会被选送成为专业运动员，为未来的升学和职业发展开辟一条全新的道路。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 style="margin-bottom:24px;">预约免费体验课</h2>
      <a href="/contact/" class="btn btn-primary">立即预约</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  .course-hero-img {
    width: 100%;
    max-width: 500px;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .course-intro {
    color: var(--c-text-muted);
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>
