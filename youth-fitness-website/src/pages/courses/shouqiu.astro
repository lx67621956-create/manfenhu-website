---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="手球专项特训 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-accent), #00E676);">
    <div class="container"><h1>手球专项特训</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items:start;">
        <div class="placeholder" style="min-height:300px;">📷 课程封面图</div>
        <div>
          <h2 style="margin-bottom:16px;">课程介绍</h2>
          <p class="text-muted" style="margin-bottom:24px;">课程详细介绍待填写...</p>
          <h3 style="margin-bottom:12px;">训练内容</h3>
          <ul class="feature-list">
            <li>🤾 基础技术训练</li>
            <li>🤝 战术配合训练</li>
            <li>🏆 比赛实战演练</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--c-surface);">
    <div class="container">
      <h2 class="section-title">课程安排</h2>
      <div class="placeholder" style="min-height:200px;">📅 课时安排表格待填写</div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 style="margin-bottom:24px;">预约免费体验课</h2>
      <a href="/contact/" class="btn btn-primary">立即预约</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  .text-muted { color: var(--c-text-muted); }
  .feature-list { padding-left: 20px; }
  .feature-list li { margin-bottom: 8px; color: var(--c-text-muted); }
</style>
