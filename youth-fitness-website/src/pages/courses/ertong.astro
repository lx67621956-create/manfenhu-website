---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="少儿体能训练 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-secondary), #00B8D4);">
    <div class="container"><h1>少儿体能训练</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items:start;">
        <img src="/images/courses/ertong.jpg.png" alt="少儿体能训练" class="course-hero-img" />
        <div class="course-content">
          <h2 style="margin-bottom:16px;">快乐运动，健康成长</h2>
          <p class="course-intro">
            针对 4-12 岁儿童的身心发展特点，我们推出了充满趣味的少儿体能训练课程。采用小班教学模式，注重个体化指导，让每个孩子都能在轻松愉快的氛围中运动。每节课 90 分钟，我们通过丰富多彩的游戏和活动，进行基础体能训练，不仅能增强孩子的体质，更能有效培养他们的运动兴趣和良好习惯，引导青少年爱上体育，为健康人生打下坚实基础。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 style="margin-bottom:24px;">预约免费体验课</h2>
      <a href="/contact/" class="btn btn-primary">立即预约</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  .course-hero-img {
    width: 100%;
    max-width: 500px;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .course-intro {
    color: var(--c-text-muted);
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>
