---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="少儿体能训练 - 青少年体能培训机构">
  <section class="page-hero" style="background:linear-gradient(135deg, var(--c-secondary), #00B8D4);">
    <div class="container"><h1>少儿体能训练</h1></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items:start;">
        <img src="/images/courses/ertong.jpg.png" alt="少儿体能训练" class="course-hero-img" />
        <div>
          <h2 style="margin-bottom:16px;">课程介绍</h2>
          <p class="text-muted" style="margin-bottom:24px;">课程详细介绍待填写...</p>
          <h3 style="margin-bottom:12px;">适龄阶段</h3>
          <ul class="feature-list">
            <li>👶 4-6岁 启蒙阶段</li>
            <li>🧒 7-9岁 基础阶段</li>
            <li>👦 10-12岁 进阶阶段</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--c-surface);">
    <div class="container">
      <h2 class="section-title">课程安排</h2>
      <div class="placeholder" style="min-height:200px;">📅 课时安排表格待填写</div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 style="margin-bottom:24px;">预约免费体验课</h2>
      <a href="/contact/" class="btn btn-primary">立即预约</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { color: #fff; padding: 48px 0; text-align: center; }
  .page-hero h1 { font-size: 2rem; }
  .text-muted { color: var(--c-text-muted); }
  .feature-list { padding-left: 20px; }
  .feature-list li { margin-bottom: 8px; color: var(--c-text-muted); }
  .course-hero-img {
    width: 100%;
    max-width: 500px;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
</style>
